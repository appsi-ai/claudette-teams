# =============================================================================
# Claudette-Teams configuration
# =============================================================================
# The Agents SDK reads auth config from this hierarchical (double-underscore)
# schema. These three come from your Azure Bot resource / app registration.
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTID=
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTSECRET=
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__TENANTID=

# Local-only: allow unauthenticated requests so the Bot Framework Emulator
# works without real creds. NEVER set this in Azure/production.
# CONNECTIONS__SERVICE_CONNECTION__SETTINGS__ANONYMOUS_ALLOWED=True

# Working directory Claude runs in (where financial analysis happens).
PROJECT_DIR=C:\path\to\your\working-directory

# Port the aiohttp server listens on. Teams/Azure post to /api/messages.
PORT=3978

# -----------------------------------------------------------------------------
# Authorization — comma-separated Microsoft Entra (AAD) object IDs.
# This is activity.from.aadObjectId, NOT the Teams display name or UPN.
# If empty, ANYONE who can reach the bot is authorized. Fill this in.
# -----------------------------------------------------------------------------
AUTHORIZED_USERS=

BOT_DISPLAY_NAME=Claudette

# Permission tiers (keyed by AAD object id, same as AUTHORIZED_USERS).
# SUPERVISOR_USERS get --permission-mode bypassPermissions. Defaults to AUTHORIZED_USERS.
SUPERVISOR_USERS=
# RESTRICTED_USERS get --permission-mode dontAsk + tool allow/deny lists.
RESTRICTED_USERS=
RESTRICTED_ALLOWED_TOOLS=Read,Edit,Write,Grep,Glob,Bash,WebSearch,WebFetch,Agent
RESTRICTED_DISALLOWED_TOOLS=

# Optional — only respond in channels whose names start with one of these
# comma-separated prefixes. Empty = respond everywhere.
ALLOWED_CHANNELS=

# Optional — trust battery directory (per-user JSON files for autonomy tiers).
TRUST_BATTERY_DIR=

# Optional — Claude CLI knobs.
CLAUDE_TIMEOUT=7200
CLAUDE_MODEL=claude-opus-4-6[1m]
CLAUDE_EFFORT=medium

# -----------------------------------------------------------------------------
# File uploads in channels / group chats (Microsoft Graph + SharePoint).
# 1:1 (personal) chats use the FileConsentCard flow and need none of this.
# For channels, set the SharePoint site id the bot uploads to, and grant the
# app Sites.ReadWrite.All (admin consent). Leave blank to disable channel uploads.
# -----------------------------------------------------------------------------
SHAREPOINT_SITE_ID=
